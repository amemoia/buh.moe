---
const { title, date, url, tags, desc } = Astro.props;
import CalendarIcon from "~icons/lucide/calendar";
---

<div class="block gap-2">
    <a class="font-bold text-2xl md:text-3xl text-fancy" href={url} target="_blank">{title}</a>
    <span class="text-sm flex flex-row gap-2">
        <span class="flex flex-row gap-1 accent-green"><CalendarIcon /> {date}</span>
        <span>•</span>
        <span>{tags.join(", ")}</span>
    </span>
    <p class="text-xl font-light">{desc}</p>
</a>