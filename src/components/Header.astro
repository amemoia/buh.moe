---
import Image from "astro/components/Image.astro"
import HeaderLogo from "../assets/buh-inverse.png";
---

<header class="mt-4">
    <div class="flex flex-col lg:flex-row w-full lg:max-w-4xl mx-auto">
        <a class="header-icon w-full lg:w-auto justify-center lg:justify-start" href="/">
            <span class="text-2xl">💢 buh.moe</span>
        </a>
        <nav class="header-links w-full lg:w-auto justify-center lg:justify-end self-stretch lg:self-center flex-wrap py-2 px-4 lg:p-0">
            <a href="/">home</a>
            <a href="/about">about</a>
            <a href="/blog">blog</a>
            <a href="/projects">projects</a>
            <a href="/devices">devices</a>
            <a href="/guestbook">guestbook</a>
            <a href="/ask">ask</a>
            <a href="/ffxiv">ffxiv</a>
        </nav>

    </div>
</header>
<script>
    const normalizePath = (path: string | undefined) => {
        if (!path) return '/';
        if (path.length > 1 && path.endsWith('/')) return path.slice(0, -1);
        return path;
    };

    const currentPath = normalizePath(window.location.pathname);
    const links = document.querySelectorAll('.header-links a[href]');

    links.forEach((link) => {
        const href = link.getAttribute('href') ?? '/';
        const linkPath = normalizePath(new URL(href, window.location.origin).pathname);
        if (linkPath === currentPath) {
            link.classList.add('active');
        }
    });
</script>
<style>
    .header-icon {
        display: flex;
        align-items: center;
        flex-shrink: 0;
    }
    header {
        font-family: 'Valve Oracle', sans-serif;
        font-weight: 500;
        background-color: black;
        border-bottom: 1px solid #BE1931;
        font-size: 18px;
        min-height: 64px;
        color: white;

        display: flex;
        flex-direction: row;
        align-items: center;
        width: 100%;
        overflow: hidden;
    }
    .header-links {
        display: flex;
        flex-direction: row;
        gap: 1rem 2em;
        align-items: center;
        overflow-x: auto;
        overflow-y: hidden;
        flex: 1;
        min-height: 64px;
        white-space: nowrap;
    }
    .header-links a {
        flex-shrink: 0;
        position: relative;
    }
    .header-links a.active::after {
        content: '';
        position: absolute;
        bottom: -19px;
        left: 0;
        right: 0;
        height: 3px;
        background-color: #BE1931;
    }
    .header-icon img {
        height: 100%;
        width: 64px;
        min-width: 64px;
    }

    @media (min-width: 1024px) {
        header {
            height: 64px;
        }

        .header-links {
            height: 100%;
        }
    }

    @media (max-width: 1023px) {
        header {
            align-items: stretch;
            border-color: transparent;
        }

        .header-links a.active::after {
            bottom: -4px;
        }

        .header-icon {
            height: 64px;
            width: 100%;
        }

        .header-links {
            width: 100%;
            flex: 0 0 auto;
        }
    }
</style>