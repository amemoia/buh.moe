---
import { env } from 'cloudflare:workers';

const { results: messages } = await env.DB
    .prepare('select id, name, message, created_at from Guestbook order by RANDOM() limit 3')
    .all();
---

<div class="widget-guestbook ml-2">
    <div class="flex flex-col gap-2 mt-2">
        {messages.map((entry) => (
            <div class="flex flex-col">
                <span class="font-bold fancy pulp">{entry.name}</span>
                <span class="italic">"{entry.message}"</span>
            </div>
        ))}
        {messages.length === 0 && <span class="italic opacity-50">No messages yet...</span>}
    </div>
</div>