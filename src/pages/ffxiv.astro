---
const lodestone = "https://eu.finalfantasyxiv.com/lodestone/character/46616687/"
const render = "https://img2.finalfantasyxiv.com/f/64b19500c983d0191dadd6a9dbf9d9fe_f2d324d722b28bbe681b2898bcdca8bffl0.jpg?1776977463"

const name = "Mina Ha";
const world = "✿ Halicarnassus";
const datacenter = "Dynamis"
const fc = "Mouro";
const msq = "Post-Dawntrail"
const levels = {
    viper: "100",
    pictomancer: "100",
    bard: "100",
    // whitemage: "60",
    // warrior: "50",
    carpenter: "100",
    blacksmith: "100",
    armorer: "100",
    goldsmith: "100",
    leatherworker: "100",
    weaver: "100",
    alchemist: "100",
    culinarian: "100",
    miner: "100",
    botanist: "100",
    fisher: "100",
}

const healers = ["whitemage", "scholar", "astrologian", "sage"];
const tanks   = ["paladin", "warrior", "dark knight", "gunbreaker"];
const crafters = ["carpenter", "blacksmith", "armorer", "goldsmith", "leatherworker", "weaver", "alchemist", "culinarian"];
const gatherers = ["miner", "botanist", "fisher"];

const entries = Object.entries(levels);
const tankJobs = entries.filter(([jobname]) => tanks.includes(jobname));
const healerJobs = entries.filter(([jobname]) => healers.includes(jobname));
const dpsJobs = entries.filter(([jobname]) => !healers.includes(jobname) && !tanks.includes(jobname) && !crafters.includes(jobname) && !gatherers.includes(jobname));
const crafterJobs = entries.filter(([jobname]) => crafters.includes(jobname));
const gathererJobs = entries.filter(([jobname]) => gatherers.includes(jobname));

import Base from '../layouts/Base.astro';
import Block from "../components/Block.astro";
import Lightbox from "../components/Lightbox.astro";
import type { ImageMetadata } from 'astro';

const pageDesc = name+" "+world+" ("+datacenter+")";

const customDescriptions: Record<string, string> = {
    "screenshot-24-09-2023.png": "a young b'occhi rhock during ARR... she does not know what awaits her...",
    "screenshot-30-09-2023.png": "late ARR bocchi!",
    "screenshot-07-11-2023.jpg": "stormblood bocchi in a very scary shirogane...",
    "screenshot-09-11-2023.jpg": "stormblood bocchi on top of kugane tower!",
    "screenshot-25-11-2023.png": "pretty much the only time i've modded my character, this was for an event held by my old FC",
    "screenshot-28-02-2024.png": "she owns a car now",
    "screenshot-13-03-2024.png": "Shadowbringers complete!",
    "screenshot-21-04-2024.png": "hanging out with my favorite little chud son",
    "gpose-25-05-2024.png": "beach photoshoot with my old FC! idk what happened to the original image so heres a screenshot of discord screenshare",
    "screenshot-07-06-2024.png": "truth nvke",
    "screenshot-13-06-2024.png": "hanging out with my chud son whom i love",
    "screenshot-28-06-2024.png": "she is a little bit shady",
    "screenshot-29-06-2024.jpg": "checking out the graphics update!",
    "screenshot2-03-07-2024.jpg": "bocchi was still using a different hairstyle in-game at this time, but the plan was to go back to this one for Dawntrail",
    "screenshot1-03-07-2024.jpg": "dawntrail benchmark cat! getting ready to explore",
    "screenshot-04-07-2024.png": "very rare handsome red mage bocchi",
    "screenshot2-28-07-2024.jpg" : "concerning.",
    "screenshot1-28-07-2024.png" : "she does not understand a single thing thats going on",
    "screenshot-28-07-2024.png": "there is not a single thought behind those blue orbs. late endwalker bocchi",
    "screenshot-29-07-2024.png": "she thinks shes so tuff. edgy red mage",
    "screenshot-05-08-2024.jpg": "a pictomancer but kinda edgy and fucked up",
    "screenshot-23-08-2024.jpg": "B'occhi between Endwalker and Dawntrail",
    "screenshot1-06-09-2024.png": "Goro Majima outfit for my Ninja job",
    "screenshot2-06-09-2024.png": "Kiryu glamour for Monk",
    "gpose1-06-08-2025.jpg": "Viper Gpose (1)",
    "gpose2-06-08-2025.jpg": "Viper Gpose (2)",
    "gpose3-06-08-2025.jpg": "Viper Gpose (3)",
    "screenshot2-21-03-2026.webp": "driving with my friends before a raid !!",
    "screenshot1-21-03-2026.webp": "waiting on one last person before raiding...",
    "screenshot-18-04-2026.png": "Buh is watching.",
    "gpose-10-04-2026.jpg": "Gpose: Cosplaying Snake from METAL GEAR SOLID 3 and MGSV Ground Zeroes",
    "screenshot-13-04-2026.png": "A new adventurer plate!",
    "screenshot-18-04-2026.jpg": "rocking a new hairstyle for post-Dawntrail (feat. Miner relic)",
};

const images = Object.entries(import.meta.glob<{ default: ImageMetadata }>('../assets/gallery/ffxiv/*.{jpg,jpeg,png,webp}', { eager: true }))
    .map(([path, m]) => {
        const filename = path.split('/').pop() || '';
        return {
            src: m.default.src,
            description: customDescriptions[filename] || ""
        };
    })
    .sort((a, b) => {
        const getDateString = (src: string) => src.match(/(\d{2})-(\d{2})-(\d{4})/)?.slice(1).reverse().join('-');
        return (getDateString(b.src) || '').localeCompare(getDateString(a.src) || '');
    });
---
<Base
    title = "buh / ffxiv"
    description = {pageDesc}
    image = "https://img2.finalfantasyxiv.com/f/64b19500c983d0191dadd6a9dbf9d9fe_f2d324d722b28bbe681b2898bcdca8bffc0.jpg?1777373463"
>
    <Block class="noborder font-light gap-4 px-1! lg:px-0!">
        <a href={lodestone} target="_blank" class="flex-col flex font-bold text-2xl md:text-3xl text-fancy text-center">
            <span>{name}</span>
            <span class="text-center italic text-xl font-normal opacity-80">(Formerly B'occhi Rhock)</span>
        </a>

        <div class="flex flex-row gap-8">

                <a href={lodestone} target="_blank" class="ffxiv-render-wrap">
                    <img src={render} class="ffxiv-render" alt="Mina Ha character render" loading="lazy" decoding="async" />
                </a>

            <div class="flex flex-col gap-4 grow self-center font-medium">

                <div class="flex flex-col">
                    <span class="accent-blue text-2xl">World</span>
                    <span>{world} <span class="font-light opacity-80">({datacenter})</span></span>
                </div>

                <div class="flex flex-col">
                    <span class="accent-purple text-2xl">Free Company</span>
                    <span>{fc} <span class="font-light opacity-80">(Engineer)</span></span>
                </div>

                <div class="flex flex-col">
                    <span class="accent-yellow text-2xl">MSQ Progress</span>
                    <span>{msq}</span>
                </div>

            </div>
        </div>

        <div class="flex flex-col gap-2 items-center">
            <span class="font-extrabold">Jobs</span>
            <div class="jobs-list flex flex-col gap-2 font-medium items-center">
                {tankJobs.length > 0 && (
                <div class="job job-tank">
                    {tankJobs.map(([jobname, level]) => (
                            <div class="classjob classjob-tank">
                                <img src={`/classjob/${jobname}.png`} alt={jobname} class="ffxiv-jobicon" width="24" height="24" loading="lazy" decoding="async" />
                                <span>{level}</span>
                            </div>
                        ))}
                </div>
                )}
                {healerJobs.length > 0 && (
                <div class="job job-healer">
                    {healerJobs.map(([jobname, level]) => (
                            <div class="classjob classjob-healer">
                                <img src={`/classjob/${jobname}.png`} alt={jobname} class="ffxiv-jobicon" width="24" height="24" loading="lazy" decoding="async" />
                                <span>{level}</span>
                            </div>
                        ))}
                </div>
                )}
                {dpsJobs.length > 0 && (
                <div class="job job-dps gap-2">
                    {dpsJobs.map(([jobname, level]) => (
                            <div class="classjob classjob-dps">
                                <img src={`/classjob/${jobname}.png`} alt={jobname} class="ffxiv-jobicon" width="24" height="24" loading="lazy" decoding="async" />
                                <span>{level}</span>
                            </div>
                        ))}
                </div>
                )}
                {crafterJobs.length > 0 && (
                <div class="job job-crafter gap-2">
                    {crafterJobs.map(([jobname, level]) => (
                            <div class="classjob classjob-crafter">
                                <img src={`/classjob/${jobname}.png`} alt={jobname} class="ffxiv-jobicon" width="24" height="24" loading="lazy" decoding="async" />
                                <span>{level}</span>
                            </div>
                        ))}
                </div>
                )}
                {gathererJobs.length > 0 && (
                <div class="job job-gatherer gap-2">
                    {gathererJobs.map(([jobname, level]) => (
                            <div class="classjob classjob-gatherer">
                                <img src={`/classjob/${jobname}.png`} alt={jobname} class="ffxiv-jobicon" width="24" height="24" loading="lazy" decoding="async" />
                                <span>{level}</span>
                            </div>
                        ))}
                </div>
                )}
            </div>
        </div>

        <Block class="ffxiv-lore gap-4 text-xl md:text-2xl lg:mt-8! noborder px-1! lg:px-2!">
            <h1 class="font-bold text-2xl md:text-3xl text-fancy text-center">A new start...</h1>
            <p>Previously forced to work as a weapons engineer for the Garlean Empire, Mina hoped that escaping to her homeland of Gridania would mean distancing herself from wars. Suffice it to say that she does not particularly enjoy being the Warrior of Light.</p>
            <p>After more than her fair share of fighting, this experienced adventurer seeks to lay down her weapon and contribute to various war restoration efforts across the star, though fate usually has other plans.</p>
            <p>Additionally, she now lends her technical expertise to her Free Company, handling all manner of engineering projects for her friends.</p>
        </Block>
    </Block>

    <Block class="noborder font-light pt-0!">
        <h1 class="font-bold text-2xl md:text-3xl pulp text-center">Gallery</h1>
        
        <div class="gallery-grid">
            {images.map((image, index) => (
                <button 
                    onclick={`window.openLightbox(${index})`}
                    class="gallery-item"
                >
                    <img
                        src={image.src}
                        alt={image.description}
                        loading="lazy"
                        decoding="async"
                        class="gallery-image"
                    />
                </button>
            ))}
        </div>
        
        <Lightbox images={images} />
    </Block>
</Base>

<style>
    .ffxiv-render-wrap {
        width: 50%;
        height: 300px;
        overflow: hidden;
        border-radius: 8px;
        border: 2px solid #7a8bd9;
        flex-shrink: 0;
    }

    .ffxiv-render {
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center 10%;
        transform: scale(2);
        transform-origin: center top;
    }
    .job {
        display: flex;
        flex-direction: row;
        flex-wrap: wrap;
        justify-content: center;
    }
    .classjob {
        display: flex;
        flex-direction: row;
        align-items: center;
        gap: 0.25em;
        background: #1c1113;
        padding: 0.25em;
        padding-right: 0.30em;
        border-radius: 6px;
        border: 1px solid #BE193180;
    }

    .classjob-tank {
        background: #13202e;
        border-color: #7aa6d9;
    }

    .classjob-healer {
        background: #14241b;
        border-color: #67b487;
    }

    .classjob-dps {
        background: #2a1717;
        border-color: #c78181;
    }

    .classjob-crafter {
        background: #24162d;
        border-color: #a888c7;
    }

    .classjob-gatherer {
        background: #2a2116;
        border-color: #c9a366;
    }

    .ffxiv-jobicon {
        width: 24px;
        height: 24px;
    }

    .gallery-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 0.5rem;
        margin-top: 1.5rem;
        max-width: 810px;
        margin-inline: auto;
    }

    .gallery-item {
        overflow: hidden;
        border-radius: 4px;
        aspect-ratio: 16 / 9;
        cursor: pointer;
        border: none;
        padding: 0;
        background: none;
    }

    .gallery-image {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .gallery-item:hover .gallery-image {
        filter: brightness(1.1);
    }

    @media (max-width: 768px) {
        .gallery-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

</style>