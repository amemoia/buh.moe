---
const {
	title = "buh.moe",
	description = "my little corner of the internet",
	image = "/resources/minibuh.png",
	url,
} = Astro.props;

const siteBase = Astro.site ?? '';
const pageUrl = url ?? (siteBase ? new URL(Astro.url.pathname, siteBase).href : Astro.url.pathname);
let absoluteImage = image;
if (image) {
	if (image.startsWith('https')) {
		absoluteImage = image;
	} else if (image.startsWith('/')) {
		absoluteImage = new URL(image, Astro.url).href;
	}
}

import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
import '../styles/global.css'
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta name="theme-color" content="#BE1931" />

		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={pageUrl} />
		<meta property="og:image" content={absoluteImage} />
		<meta property="og:site_name" content="buh.moe" />

		<!-- Twitter -->
		<meta name="twitter:card" content="summary" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={absoluteImage} />

		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
        <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
        <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
		<link rel="alternate" type="application/rss+xml" href="/rss.xml" title="buh.moe RSS" />
	</head>

	<body class="flex flex-col">
		<Header />
		<main class="flex flex-col text-lg lg:text-xl lg:w-4xl self-center mt-8 mx-2 lg:mx-0">
			<slot />
		</main>
		<Footer />
	</body>
</html>

<script>
	import twemoji from 'twemoji';
	document.addEventListener('DOMContentLoaded', () => {
		twemoji.parse(document.body, {
			folder: 'svg',
			ext: '.svg'
		});
	});
</script>